[{"verse":1,"arabic":"قُلْ هُوَ ٱللَّهُ أَحَدٌ","translation":"Say, \"He is Allah, [who is] One,"},{"verse":2,"arabic":"ٱللَّهُ ٱلصَّمَدُ","translation":"Allah, the Eternal Refuge."},{"verse":3,"arabic":"لَمْ يَلِدْ وَلَمْ يُولَدْ","translation":"He neither begets nor is born,"},{"verse":4,"arabic":"وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌۢ","translation":"Nor is there to Him any equivalent.\""}]