[{"verse":1,"arabic":"قُلْ أَعُوذُ بِرَبِّ ٱلنَّاسِ","translation":"Say, \"I seek refuge in the Lord of mankind,"},{"verse":2,"arabic":"مَلِكِ ٱلنَّاسِ","translation":"The Sovereign of mankind."},{"verse":3,"arabic":"إِلَٰهِ ٱلنَّاسِ","translation":"The God of mankind,"},{"verse":4,"arabic":"مِن شَرِّ ٱلْوَسْوَاسِ ٱلْخَنَّاسِ","translation":"From the evil of the retreating whisperer -"},{"verse":5,"arabic":"ٱلَّذِى يُوَسْوِسُ فِى صُدُورِ ٱلنَّاسِ","translation":"Who whispers [evil] into the breasts of mankind -"},{"verse":6,"arabic":"مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ","translation":"From among the jinn and mankind.\""}]