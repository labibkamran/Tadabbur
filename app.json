{
  "expo": {
    "name": "Tadabbur",
    "slug": "Tadabbur",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/tadabbur/tadabbur-icon.png",
    "scheme": "tadabbur",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#14493C",
        "foregroundImage": "./assets/images/tadabbur/tadabbur-icon-foreground.png",
        "backgroundImage": "./assets/images/tadabbur/tadabbur-icon-background.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/tadabbur/tadabbur-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#14493C",
          "image": "./assets/images/tadabbur/tadabbur-icon-foreground.png",
          "imageWidth": 120
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
