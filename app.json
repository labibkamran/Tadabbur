{
  "expo": {
    "name": "Tadabbur",
    "slug": "Tadabbur",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/tadabbur/tadabbur-icon.png",
    "scheme": "tadabbur",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#14493C",
        "foregroundImage": "./assets/images/tadabbur/tadabbur-icon-foreground.png",
        "backgroundImage": "./assets/images/tadabbur/tadabbur-icon-background.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Tadabbur"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/tadabbur/tadabbur-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FBF8F3",
          "image": "./assets/images/tadabbur/tadabbur-icon.png",
          "imageWidth": 120,
          "dark": {
            "backgroundColor": "#10120F",
            "image": "./assets/images/tadabbur/tadabbur-icon.png"
          }
        }
      ],
      "expo-image",
      "expo-status-bar",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aaadaab8-aafc-4651-9965-8b8b859b978b"
      }
    }
  }
}
